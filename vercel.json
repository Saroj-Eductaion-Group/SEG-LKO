{
  "build": {
    "env": {
      "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
    }
  },
  "rewrites": [
    {
      "source": "/ssitm/:path*",
      "destination": "/ssitm/:path*"
    },
    {
      "source": "/ssitm",
      "destination": "/ssitm/index.html"
    },
    {
      "source": "/((?!ssitm).*)",
      "destination": "/$1"
    }
  ]
}
